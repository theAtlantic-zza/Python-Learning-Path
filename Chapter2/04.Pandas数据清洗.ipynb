   "source": [
    "'''数据清洗是指发现并纠正数据中可识别的错误的过程\n",
    "   包括处理缺失值,重复值,异常值,统一数据格式\n",
    "'''\n",
    "import pandas as pd\n",
    "pd.set_option('display.min_rows', 30)#设置显示行数(默认10行)\n",
    "\n",
    "#1.读取数据\n",
    "df = pd.read_csv('data/sales02.csv')\n",
    "\n",
    "#2. 数据清洗\n",
    "#2.1 缺失值处理\n",
    "print(df.isnull().head(3)) #df.isnull 查看缺失值\n",
    "\n",
    "#2.1.1 删除缺失值\n",
    "df.dropna()#df.dropna 删除缺失"
   ],
